{
  "info": {
    "name": "JobAI API health check",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health endpoint",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/health"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('returns 200', function () { pm.response.to.have.status(200); });",
              "const body = pm.response.json();",
              "pm.test('returns ok status', function () { pm.expect(body.status).to.eql('ok'); });",
              "pm.test('returns a health message', function () { pm.expect(body.message).to.include('healthy'); });"
            ]
          }
        }
      ]
    }
  ]
}
