{
  "name": "jobai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test:unit": "vitest run",
    "test:api": "npx newman run postman/jobai-api.collection.json --env-var baseUrl=http://127.0.0.1:3000 --reporters cli,junit --reporter-junit-export reports/newman-results.xml",
    "test:e2e": "npx playwright test",
    "test": "npm run test:unit && npm run test:api && npm run test:e2e",
    "test:ci": "npm run build && npx next start -p 3000 > /tmp/next.log 2>&1 & npx wait-on http://127.0.0.1:3000 && npm run test"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.4.0",
    "axios": "^1.18.0",
    "clsx": "^2.1.1",
    "firebase": "^12.14.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.18.0",
    "mammoth": "^1.12.0",
    "next": "14.2.35",
    "openai": "^6.42.0",
    "pdf-parse": "^1.1.1",
    "react": "^18",
    "react-dom": "^18",
    "react-dropzone": "^15.0.0",
    "react-hook-form": "^7.79.0",
    "react-hot-toast": "^2.6.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "newman": "^5.3.1",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "vitest": "^0.34.4",
    "wait-on": "^9.0.10"
  }
}
